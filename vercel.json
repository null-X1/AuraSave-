{
  "version": 2,

  "builds": [
    {
      "src": "api/download.js",
      "use": "@vercel/node"
    },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "icon.png", "use": "@vercel/static" }
  ],

  "routes": [
    {
      "src": "/api/download",
      "dest": "api/download.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
